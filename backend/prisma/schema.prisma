generator client {
  provider = "prisma-client-js"
}

datasource  preubaud{
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Consumer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  orders    Order[]
  createdAt DateTime @default(now())
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  price       Decimal
  stock       Int
  items       OrderItem[]
}

model Order {
  id         Int         @id @default(autoincrement())
  consumerId Int
  consumer   Consumer    @relation(fields: [consumerId], references: [id])
  items      OrderItem[]
  total      Decimal
  createdAt  DateTime    @default(now())
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  unitPrice Decimal

  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}